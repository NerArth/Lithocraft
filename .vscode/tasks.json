{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-File",
                "${workspaceFolder}/build.ps1",
                "-Target",
                "All",
                "-Config",
                "Debug"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build interactive",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-File",
                "${workspaceFolder}/build.ps1"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "focus": true,
                "panel": "shared"
            }
        }
    ]
}